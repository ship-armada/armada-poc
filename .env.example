# Armada Railgun Demo — Environment Variables
# Copy this file to .env and fill in values.
# For local Anvil dev, use the defaults shown in comments.

# ── Account Keys ──────────────────────────────────────────────
# Deployer / Relayer (Anvil Account 0)
DEPLOYER_PRIVATE_KEY=

# Test User 1 — optional, for local dev (Anvil Account 1)
USER1_PRIVATE_KEY=

# Test User 2 — optional, for local dev (Anvil Account 2)
USER2_PRIVATE_KEY=

# ── RPC URLs ──────────────────────────────────────────────────
# Hub chain RPC (default: http://localhost:8545)
HUB_RPC=

# Client A chain RPC (default: http://localhost:8546)
CLIENT_RPC=

# Client B chain RPC (default: http://localhost:8547)
CLIENT_B_RPC=
