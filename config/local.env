# Local Anvil Development Environment
# Usage: source config/local.env && npm run setup

# Environment identifier
export DEPLOY_ENV=local

# CCTP mode: "mock" deploys MockCCTP contracts, "real" uses Circle's deployed contracts
export CCTP_MODE=mock

# Hub chain (Anvil instance 1)
export HUB_RPC=http://localhost:8545
export HUB_CHAIN_ID=31337
export HUB_CCTP_DOMAIN=100

# Client A chain (Anvil instance 2)
export CLIENT_A_RPC=http://localhost:8546
export CLIENT_A_CHAIN_ID=31338
export CLIENT_A_CCTP_DOMAIN=101

# Client B chain (Anvil instance 3)
export CLIENT_B_RPC=http://localhost:8547
export CLIENT_B_CHAIN_ID=31339
export CLIENT_B_CCTP_DOMAIN=102

# Deployer private key (Anvil default account 0)
export DEPLOYER_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# CCTP addresses (unused in mock mode - mocks are deployed fresh)
# HUB_USDC=
# HUB_TOKEN_MESSENGER=
# HUB_MESSAGE_TRANSMITTER=

# Aave mock config
export AAVE_YIELD_BPS=5000000

# Governance config
export TIMELOCK_DELAY=172800
# Must be >= 120% of governance cycle (2d+5d+2d=9d). Default: 933120s (10.8d)
export STEWARD_DELAY=933120

# CCTP finality mode: "fast" (1000, ~8-20s, 1-1.3 bps fee) or "standard" (2000, ~15-19 min, free)
export CCTP_FINALITY_MODE=fast

# Relayer config
export RELAYER_PORT=3001
export ETH_USDC_PRICE=2000

# Treasury address (optional — defaults to deployer address if unset)
# export TREASURY_ADDRESS=0x...
