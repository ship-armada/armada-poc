# Local Anvil Development Environment
# Usage: source config/local.env && npm run setup

# Environment identifier
DEPLOY_ENV=local

# CCTP mode: "mock" deploys MockCCTP contracts, "real" uses Circle's deployed contracts
CCTP_MODE=mock

# Hub chain (Anvil instance 1)
HUB_RPC=http://localhost:8545
HUB_CHAIN_ID=31337
HUB_CCTP_DOMAIN=100

# Client A chain (Anvil instance 2)
CLIENT_A_RPC=http://localhost:8546
CLIENT_A_CHAIN_ID=31338
CLIENT_A_CCTP_DOMAIN=101

# Client B chain (Anvil instance 3)
CLIENT_B_RPC=http://localhost:8547
CLIENT_B_CHAIN_ID=31339
CLIENT_B_CCTP_DOMAIN=102

# Deployer private key (Anvil default account 0)
DEPLOYER_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# CCTP addresses (unused in mock mode - mocks are deployed fresh)
# HUB_USDC=
# HUB_TOKEN_MESSENGER=
# HUB_MESSAGE_TRANSMITTER=

# Aave mock config
AAVE_YIELD_BPS=5000000

# Governance config
TIMELOCK_DELAY=172800
STEWARD_DELAY=86400

# Relayer config
RELAYER_PORT=3001
ETH_USDC_PRICE=2000
