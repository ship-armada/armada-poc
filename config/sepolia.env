# Sepolia Public Testnet Environment
# Usage: source config/sepolia.env && npm run setup:sepolia
#
# Prerequisites:
#   - Fund deployer with Sepolia ETH from a faucet
#   - Get testnet USDC from https://faucet.circle.com/
#   - Fund deployer on each chain you're deploying to

# Environment identifier
DEPLOY_ENV=sepolia

# CCTP mode: "real" uses Circle's deployed CCTP V2 contracts
CCTP_MODE=real

# Hub chain: Ethereum Sepolia
HUB_RPC=https://ethereum-sepolia-rpc.publicnode.com
HUB_CHAIN_ID=11155111
HUB_CCTP_DOMAIN=0

# Client A chain: Base Sepolia
CLIENT_A_RPC=https://sepolia.base.org
CLIENT_A_CHAIN_ID=84532
CLIENT_A_CCTP_DOMAIN=6

# Client B chain: Arbitrum Sepolia
CLIENT_B_RPC=https://sepolia-rollup.arbitrum.io/rpc
CLIENT_B_CHAIN_ID=421614
CLIENT_B_CCTP_DOMAIN=3

# Deployer private key (MUST CHANGE - DO NOT USE ANVIL KEY ON TESTNET)
DEPLOYER_PRIVATE_KEY=

# ============================================================================
# Circle CCTP V2 Contract Addresses (same across all EVM testnets via CREATE2)
# ============================================================================
CCTP_TOKEN_MESSENGER=0x8FE6B999Dc680CcFDD5Bf7EB0974218be2542DAA
CCTP_MESSAGE_TRANSMITTER=0xE737e5cEBEEBa77EFE34D4aa090756590b1CE275
CCTP_TOKEN_MINTER=0xb43db544E2c27092c107639Ad201b3dEfAbcF192

# ============================================================================
# USDC Addresses (different per chain)
# ============================================================================
HUB_USDC=0x1c7D4B196Cb0C7B01d743Fbc6116a902379C7238
CLIENT_A_USDC=0x036CbD53842c5426634e7929541eC2318f3dCF7e
CLIENT_B_USDC=0x75faf114eafb1BDbe2F0316DF893fd58CE46AA4d

# ============================================================================
# Circle Iris Attestation Service
# ============================================================================
IRIS_API_URL=https://iris-api-sandbox.circle.com
IRIS_POLL_INTERVAL_MS=10000
IRIS_POLL_TIMEOUT_MS=600000

# ============================================================================
# Aave Mock Config (no real Aave V4 on Sepolia)
# ============================================================================
AAVE_YIELD_BPS=500

# ============================================================================
# Governance Config (shortened for testnet iteration speed)
# ============================================================================
TIMELOCK_DELAY=60
STEWARD_DELAY=30

# ============================================================================
# Relayer Config
# ============================================================================
RELAYER_PORT=3001
ETH_USDC_PRICE=2000
