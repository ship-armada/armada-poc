# Sepolia Public Testnet Environment
# Usage: source config/sepolia.env && npm run setup:sepolia
#
# Prerequisites:
#   - Copy config/secrets.env.template to config/secrets.env and add your private key
#   - Fund deployer with Sepolia ETH from a faucet
#   - Get testnet USDC from https://faucet.circle.com/
#   - Fund deployer on each chain you're deploying to

# Load secrets (private keys) from gitignored file
if [ -f "config/secrets.env" ]; then
  source "config/secrets.env"
else
  echo "WARNING: config/secrets.env not found. Copy config/secrets.env.template and add your key."
fi

# Environment identifier
export DEPLOY_ENV=sepolia

# CCTP mode: "real" uses Circle's deployed CCTP V2 contracts
export CCTP_MODE=real

# Hub chain: Ethereum Sepolia
export HUB_RPC=https://ethereum-sepolia-rpc.publicnode.com
# export HUB_RPC=https://sepolia.gateway.tenderly.co
export HUB_CHAIN_ID=11155111
export HUB_CCTP_DOMAIN=0

# Client A chain: Base Sepolia
export CLIENT_A_RPC=https://sepolia.base.org
export CLIENT_A_CHAIN_ID=84532
export CLIENT_A_CCTP_DOMAIN=6

# Client B chain: Arbitrum Sepolia
export CLIENT_B_RPC=https://sepolia-rollup.arbitrum.io/rpc
export CLIENT_B_CHAIN_ID=421614
export CLIENT_B_CCTP_DOMAIN=3

# Deployer private key — loaded from config/secrets.env (gitignored)
# See config/secrets.env.template

# ============================================================================
# Circle CCTP V2 Contract Addresses (same across all EVM testnets via CREATE2)
# ============================================================================
export CCTP_TOKEN_MESSENGER=0x8FE6B999Dc680CcFDD5Bf7EB0974218be2542DAA
export CCTP_MESSAGE_TRANSMITTER=0xE737e5cEBEEBa77EFE34D4aa090756590b1CE275
export CCTP_TOKEN_MINTER=0xb43db544E2c27092c107639Ad201b3dEfAbcF192

# ============================================================================
# USDC Addresses (different per chain)
# ============================================================================
export HUB_USDC=0x1c7D4B196Cb0C7B01d743Fbc6116a902379C7238
export CLIENT_A_USDC=0x036CbD53842c5426634e7929541eC2318f3dCF7e
export CLIENT_B_USDC=0x75faf114eafb1BDbe2F0316DF893fd58CE46AA4d

# ============================================================================
# Circle Iris Attestation Service
# ============================================================================
export IRIS_API_URL=https://iris-api-sandbox.circle.com
export IRIS_POLL_INTERVAL_MS=10000
export IRIS_POLL_TIMEOUT_MS=600000
# Frontend uses VITE_ prefix (Vite exposes only VITE_* env vars to import.meta.env)
export VITE_IRIS_ATTESTATION_BASE_URL=https://iris-api-sandbox.circle.com/attestations

# ============================================================================
# Aave Mock Config (no real Aave V4 on Sepolia)
# ============================================================================
export AAVE_YIELD_BPS=50000

# ============================================================================
# Governance Config (shortened for testnet iteration speed)
# ============================================================================
export TIMELOCK_DELAY=60

# ============================================================================
# CCTP Finality Mode
# ============================================================================
# "fast" = confirmed-level (~8-20s, 1-1.3 bps fee, Circle bears reorg risk)
# "standard" = finalized-level (~15-19 min, free)
export CCTP_FINALITY_MODE=fast

# ============================================================================
# Relayer Config
# ============================================================================
export RELAYER_PORT=3001
export ETH_USDC_PRICE=2000

# ============================================================================
# ARM Distribution (mini-Sepolia — scaled down from 12M to 1K total supply)
# ============================================================================
export ARM_TREASURY_ALLOCATION=650
export ARM_CROWDFUND_ALLOCATION=150
export ARM_REVENUE_LOCK_ALLOCATION=200

# RevenueLock beneficiaries — JSON array of {address, amount, label}.
# Amounts are whole ARM tokens (no decimals) and must sum to ARM_REVENUE_LOCK_ALLOCATION.
# For mini-Sepolia: single test beneficiary receives the full 200 ARM allocation.
# Replace the address below with a wallet you control.
export REVENUE_LOCK_BENEFICIARIES_JSON='[{"address":"0xYOUR_BENEFICIARY_ADDRESS","amount":"200","label":"test beneficiary"}]'

# ============================================================================
# Treasury Config (optional — defaults to deployer address if unset)
# ============================================================================
export TREASURY_ADDRESS=0x4cb6660a5877f28198c400C51fc1766e4647d008

# ============================================================================
# Crowdfund Config
# ============================================================================
# Delay in seconds from deployment time before the crowdfund window opens.
# Production should use a longer delay (e.g. 604800 = 7 days) to allow seed setup.
export CROWDFUND_OPEN_DELAY=3600

# ============================================================================
# Security Council (required — must differ from deployer)
# ============================================================================
# The security council holds cancel authority over the crowdfund.
# Must be a separate key from the deployer to maintain separation of powers.
export SECURITY_COUNCIL_ADDRESS=0xf9d211b55bfa4DB270A94BA4fD3e4eDCB8355CA4

# ============================================================================
# WalletConnect Config (required for WalletConnect wallet support on Sepolia)
# ============================================================================
# Get a free project ID from https://cloud.walletconnect.com
export VITE_WALLETCONNECT_PROJECT_ID=631d1fb59d6b1d5391eb445283aaf2d2
