{
  "name": "railgun-cctp-poc",
  "version": "0.4.0",
  "private": true,
  "workspaces": [
    "usdc-v2-frontend"
  ],
  "scripts": {
    "compile": "hardhat compile",
    "chains": "./scripts/setup_chains.sh",
    "setup": "npm run compile && npm run deploy:cctp && npm run deploy:privacy-pool && npm run deploy:aave && npm run deploy:yield && npm run link && npm run deploy:faucets",
    "deploy:cctp:hub": "hardhat run scripts/deploy_cctp_v3.ts --network hub",
    "deploy:cctp:client": "hardhat run scripts/deploy_cctp_v3.ts --network client",
    "deploy:cctp:clientB": "hardhat run scripts/deploy_cctp_v3.ts --network clientB",
    "deploy:cctp": "npm run deploy:cctp:hub && npm run deploy:cctp:client && npm run deploy:cctp:clientB",
    "deploy:privacy-pool:hub": "hardhat run scripts/deploy_privacy_pool.ts --network hub",
    "deploy:privacy-pool:client": "hardhat run scripts/deploy_privacy_pool.ts --network client",
    "deploy:privacy-pool:clientB": "hardhat run scripts/deploy_privacy_pool.ts --network clientB",
    "deploy:privacy-pool": "npm run deploy:privacy-pool:hub && npm run deploy:privacy-pool:client && npm run deploy:privacy-pool:clientB",
    "deploy:aave:hub": "hardhat run scripts/deploy_aave_mock.ts --network hub",
    "deploy:aave": "npm run deploy:aave:hub",
    "deploy:yield:hub": "hardhat run scripts/deploy_yield.ts --network hub",
    "deploy:yield": "npm run deploy:yield:hub",
    "deploy:faucets": "hardhat run scripts/deploy_faucet.ts",
    "link": "hardhat run scripts/link_privacy_pool.ts --network hub",
    "relayer": "npx ts-node relayer/relay-v2.ts",
    "test": "hardhat test test/privacy_pool_integration.ts",
    "clean": "rm -rf deployments/*.json artifacts cache typechain-types data/railgun-db",
    "demo": "cd usdc-v2-frontend && npm run dev",
    "demo:build": "cd usdc-v2-frontend && npm run build",
    "demo:old": "cd demo-app && npm run prepare-artifacts && npm run dev"
  },
  "dependencies": {
    "@nomicfoundation/hardhat-chai-matchers": "^2.1.0",
    "@nomicfoundation/hardhat-ethers": "^3.1.3",
    "@nomicfoundation/hardhat-network-helpers": "^1.1.2",
    "@nomicfoundation/hardhat-verify": "^2.1.3",
    "@openzeppelin/contracts": "^4.9.3",
    "@openzeppelin/contracts-upgradeable": "^4.9.3",
    "@railgun-community/engine": "9.5.1",
    "@railgun-community/shared-models": "8.0.0",
    "@railgun-community/wallet": "10.8.1",
    "@typechain/ethers-v6": "^0.5.1",
    "@typechain/hardhat": "^9.1.0",
    "@types/chai": "^4.3.20",
    "@types/mocha": "^10.0.10",
    "abstract-leveldown": "^7.2.0",
    "chai": "^4.5.0",
    "circomlibjs": "^0.1.7",
    "dotenv": "^16.3.1",
    "encoding-down": "^7.1.0",
    "ethers": "^6.14.0",
    "hardhat-gas-reporter": "^1.0.10",
    "leveldown": "^6.1.1",
    "levelup": "^5.1.1",
    "snarkjs": "^0.7.0",
    "solidity-coverage": "^0.8.17",
    "typechain": "^8.3.2"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^4.0.0",
    "@types/abstract-leveldown": "^7.2.1",
    "@types/encoding-down": "^5.0.1",
    "@types/levelup": "^5.1.2",
    "@types/node": "^20.11.0",
    "@types/snarkjs": "^0.7.8",
    "hardhat": "^2.19.4",
    "railgun-circuit-test-artifacts": "https://ipfs-lb.com/ipfs/QmPvs6Lws1MS4CTMAQ6P3WfyFpWFKGu7o6cSbWCu3vgXLW/railgun-circuit-test-artifacts-0.0.1.tgz",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.2"
  }
}
