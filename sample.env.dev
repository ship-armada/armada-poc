# Armada crowdfund local development environment targeting Sepolia.
# Copy to dev.env, adjust RPC URLs as needed, then run: set -a; source dev.env; set +a

# ============================================================================
# Crowdfund Sepolia deployment
# ============================================================================
CROWDFUND_CHAIN_ID=11155111
CROWDFUND_CONTRACT_ADDRESS=0xF681A7c700420e5CA93f77c8988d3eED02767035
CROWDFUND_DEPLOY_BLOCK=10743481

# Use a private/paid RPC for better reliability if available.
CROWDFUND_PRIMARY_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
CROWDFUND_AUDIT_RPC_URL=https://sepolia.gateway.tenderly.co

# ============================================================================
# Indexer API
# ============================================================================
CROWDFUND_INDEXER_PORT=3002
CROWDFUND_INDEXER_STORE=file
CROWDFUND_INDEXER_STORE_PATH=data/crowdfund-indexer/sepolia-store.json

# Run continuous polling in dev so the indexer catches up without manual backfill.
CROWDFUND_POLL_ON_START=true
CROWDFUND_BACKFILL_ON_START=false
CROWDFUND_POLL_INTERVAL_MS=15000
CROWDFUND_POLL_ERROR_BACKOFF_MS=60000

# RPC safety controls.
CROWDFUND_RPC_TIMEOUT_MS=15000
CROWDFUND_RPC_MAX_RETRIES=3
CROWDFUND_RPC_RETRY_BASE_DELAY_MS=1000
CROWDFUND_RPC_RETRY_JITTER_MS=250

# Range planning. Use lower confirmation depth locally if you want faster UI tests.
CROWDFUND_CONFIRMATION_DEPTH=2
CROWDFUND_OVERLAP_WINDOW=100
CROWDFUND_MAX_BLOCK_RANGE=500

# Local file snapshot publication for dev smoke tests.
CROWDFUND_PUBLISH_ON_POLL=false
CROWDFUND_SNAPSHOT_PUBLISH_INTERVAL_MS=60000
CROWDFUND_SNAPSHOT_PUBLISHER=file
CROWDFUND_SNAPSHOT_DIR=data/crowdfund-indexer/snapshots

# ============================================================================
# Crowdfund committer / observer Vite apps
# ============================================================================
VITE_NETWORK=sepolia
VITE_SEPOLIA_RPC=https://ethereum-sepolia-rpc.publicnode.com
VITE_SEPOLIA_RPC_FALLBACK=https://sepolia.gateway.tenderly.co
VITE_CROWDFUND_INDEXER_URL=http://localhost:3002
VITE_WALLETCONNECT_PROJECT_ID=631d1fb59d6b1d5391eb445283aaf2d2
